# Database 
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# JWT
SECRET_KEY=your_secret_key_here  # generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail SMTP - dùng App Password, không phải mật khẩu Gmail)
# Hướng dẫn: https://myaccount.google.com/apppasswords
MAIL_USERNAME=yourbusiness@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM_NAME=GymStore
FRONTEND_URL=https://yoursite.com

# VietQR bank transfer config (used by frontend)
VITE_BANK_ID=BANK_ID
VITE_BANK_ACCOUNT_NO=ACCOUNT_NO
VITE_BANK_ACCOUNT_NAME=GYM STORE
VITE_BANK_TEMPLATE=compact
